# =============================================================================
# Fichier     : .env.example
# Description : Template de variables d'environnement pour docker-compose.yml
#               PFE IoT Security - Phase 1
#               COPIER ce fichier vers .env et adapter les valeurs
#               cp .env.example .env
# Version     : 3.0
# Auteur      : PFE IoT Security Team
# Date        : 2026-03-07
# =============================================================================

# --- Projet Docker Compose ---
COMPOSE_PROJECT_NAME=pfe-iot-security

# --- Interfaces réseau (noms réels Ubuntu Server avec VMware) ---
IFACE_VLAN10=ens33        # VMnet1 - parent macvlan VLAN10 IoT
IFACE_VLAN20=ens34        # VMnet2 - parent macvlan VLAN20 SIEM
IFACE_MGMT=ens35          # VMnet3 - Management, IP fixe
IFACE_NAT=ens36           # VMnet8 - DHCP NAT internet

# --- Interfaces réseau Docker-Host ---
DOCKER_HOST_IFACE_VLAN10=ens33
DOCKER_HOST_IFACE_VLAN20=ens34
DOCKER_HOST_IFACE_MGMT=ens35
DOCKER_HOST_IFACE_NAT=ens36
DOCKER_HOST_MGMT_IP=192.168.30.100

# --- Réseau MQTT (VLAN 10) ---
MQTT_BROKER_IP=192.168.10.20
MQTT_PORT=1883

# --- Vault PKI (VLAN 30) ---
VAULT_ADDR=http://192.168.30.10:8200
# VAULT_TOKEN=<renseigner après initialisation de Vault>

# --- Wazuh SIEM (VLAN 20) ---
WAZUH_IP=192.168.20.10
WAZUH_MANAGER_IP=192.168.20.10
WAZUH_API_PORT=55000
# WAZUH_API_USER=wazuh-wui
# WAZUH_API_PASSWORD=<renseigner>

# --- Capteurs IoT ---
SENSOR_PUBLISH_INTERVAL=5

# --- Gateway ---
GATEWAY_ID=gw-001
LOG_LEVEL=INFO

# --- Suricata IDS ---
SURICATA_INTERFACE=ens33   # Interface SPAN/miroir depuis MikroTik ether5

# TODO Phase future : CoAP/DTLS
# COAP_PORT=5684
# DTLS_ENABLED=false
